{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useGenericFontNames": "off",
        "useKeyWithClickEvents": "off",
        "useButtonType": "off"
      },
      "complexity": {
        "useOptionalChain": "off"
      },
      "style": {
        "useImportType": "off",
        "useTemplate": "off",
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off",
        "useDefaultParameterLast": "off",
        "useEnumInitializers": "off",
        "noUselessElse": "off",
        "noInferrableTypes": "off",
        "useConst": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "files": {
    "ignore": [
      "dist/**",
      "build/**",
      "coverage/**",
      "test-results/**",
      "playwright-report/**"
    ]
  }
}
